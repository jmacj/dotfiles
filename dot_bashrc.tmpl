# shellcheck shell=bash
# =============================================================================
# ~/.bashrc  —  Bash config (Windows/WSL + Linux)
# =============================================================================

# Exit if not interactive
[[ $- != *i* ]] && return

# Source shared config
# shellcheck source=dot_exports.tmpl
[ -f "$HOME/.exports" ] && source "$HOME/.exports"
# shellcheck source=dot_aliases.tmpl
[ -f "$HOME/.aliases" ] && source "$HOME/.aliases"
# shellcheck source=dot_functions
[ -f "$HOME/.functions" ] && source "$HOME/.functions"

# ---- Bash options -----------------------------------------------------------
shopt -s histappend    # append to history, don't overwrite
shopt -s checkwinsize  # update LINES/COLUMNS after each command
shopt -s cdspell       # autocorrect minor typos in cd
shopt -s autocd        # type a dir name to cd into it
shopt -s globstar      # recursive globbing (**)

# Save history after each command
PROMPT_COMMAND="history -a; $PROMPT_COMMAND"

# ---- Completion -------------------------------------------------------------
if ! shopt -oq posix; then
  if [ -f /usr/share/bash-completion/bash_completion ]; then
    source /usr/share/bash-completion/bash_completion
  elif [ -f /etc/bash_completion ]; then
    source /etc/bash_completion
  fi
fi

{{- if eq .chezmoi.os "darwin" }}
# Homebrew completions
if command -v brew &>/dev/null; then
  HOMEBREW_PREFIX="$(brew --prefix)"
  if [ -r "${HOMEBREW_PREFIX}/etc/profile.d/bash_completion.sh" ]; then
    source "${HOMEBREW_PREFIX}/etc/profile.d/bash_completion.sh"
  fi
fi
{{- end }}

# ---- Tab: navigable menu completion ----------------------------------------
# 'menu-complete' cycles through matches; combined with show-all-if-ambiguous
# it opens a navigable inline list on first Tab press.
bind 'set show-all-if-ambiguous on'
bind 'set completion-ignore-case on'
bind 'set menu-complete-display-prefix on'
bind 'TAB:menu-complete'
bind '"\e[Z":menu-complete-backward'   # Shift+Tab goes backward

# ---- nvm --------------------------------------------------------------------
# shellcheck source=/dev/null
[ -s "$NVM_DIR/nvm.sh" ] && source "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && source "$NVM_DIR/bash_completion"

# ---- fzf --------------------------------------------------------------------
# shellcheck source=/dev/null
[ -f "$HOME/.config/fzf/fzf.bash" ] && source "$HOME/.config/fzf/fzf.bash"

# ---- Starship prompt --------------------------------------------------------
command -v starship &>/dev/null && eval "$(starship init bash)"

# ---- WSL optimizations ------------------------------------------------------
if is_wsl; then
  # Use wslview as the default browser if available
  command -v wslview &>/dev/null && export BROWSER=wslview
fi

# ---- Local overrides (not committed) ----------------------------------------
# shellcheck source=/dev/null
[ -f "$HOME/.local_bashrc" ] && source "$HOME/.local_bashrc"
