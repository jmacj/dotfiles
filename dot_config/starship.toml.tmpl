# =============================================================================
# ~/.config/starship.toml  —  Starship cross-shell prompt
# Works in Bash, Zsh, and PowerShell.
# Docs: https://starship.rs/config/
# =============================================================================

"$schema" = 'https://starship.rs/config-schema.json'
palette = "{{ .theme }}"

format = """
$username\
$hostname\
$directory\
$git_branch\
$git_state\
$git_status\
$package\
$cmd_duration\
$python\
$php\
$nodejs\
$line_break\
$character"""

right_format = """
$time"""

# ---- Directory --------------------------------------------------------------
[directory]
style             = "bold blue"
truncation_length = 4
truncate_to_repo  = true

# ---- Git --------------------------------------------------------------------
[git_branch]
symbol = " "
style  = "bold purple"

[git_status]
format     = '([\[$all_status$ahead_behind\]]($style) )'
style      = "bold red"
conflicted = "⚠"
ahead      = "⇡${count}"
behind     = "⇣${count}"
diverged   = "⇕⇡${ahead_count}⇣${behind_count}"
untracked  = "?"
stashed    = "*"
modified   = "!"
staged     = "+"
renamed    = "»"
deleted    = "✘"

# ---- Languages --------------------------------------------------------------
[package]
symbol = "󰏗 "
style  = "bold orange"

[nodejs]
symbol = " "
style  = "bold green"
detect_files = ["package.json", ".node-version", "nvmrc", "package-lock.json", "npm-shrinkwrap.json", "yarn.lock", "pnpm-lock.yaml", "pnpm-workspace.yaml"]

[php]
symbol = " "
style  = "bold blue"
detect_files = ["composer.json", ".php-version", "index.php"]
detect_extensions = ["php"]

[python]
symbol = " "
style  = "bold yellow"

# ---- Command duration -------------------------------------------------------
[cmd_duration]
min_time = 2000
format   = " [$duration]($style) "
style    = "bold yellow"

# ---- Prompt character -------------------------------------------------------
[character]
success_symbol = "[❯](bold green)"
error_symbol   = "[❯](bold red)"

# ---- Time -------------------------------------------------------------------
[time]
format = "[$time]($style) "
style  = "bold yellow"
disabled = false

# ---- Username (show only in SSH) --------------------------------------------
[username]
show_always = false
style_user  = "bold cyan"
format      = "[$user]($style)@"

[hostname]
ssh_only = true
style    = "bold cyan"
format   = "[$hostname]($style) "

# ---- Palettes -------------------------------------------------------------

[palettes.jetbrains]
blue   = "#3592C4"
green  = "#629755"
orange = "#ED9439"
purple = "#9D77BD"
yellow = "#FFC66D"
red    = "#FF6B68"
grey   = "#6B6B6B"
white  = "#A9B7C6"

