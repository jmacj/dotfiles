# Nushell Environment Config File
# Generated by Antigravity based on existing shell profiles

# ---- Path Conversions -------------------------------------------------------
# Specifies how environment variables are converted from strings to values
$env.ENV_CONVERSIONS = {
  "PATH": {
    from_string: { |s| $s | split row (char esep) | path expand --no-symlink }
    to_string: { |v| $v | path expand --no-symlink | str join (char esep) }
  }
  "Path": {
    from_string: { |s| $s | split row (char esep) | path expand --no-symlink }
    to_string: { |v| $v | path expand --no-symlink | str join (char esep) }
  }
}

# Directories to search for scripts when calling them directly
$env.NU_LIB_DIRS = [
    ($nu.default-config-dir | path join 'scripts')
]

# Directories to search for plugin binaries
$env.NU_PLUGIN_DIRS = [
    ($nu.default-config-dir | path join 'plugins')
]

# ---- Basic Environment ------------------------------------------------------
$env.EDITOR = (
    ["vim", "nvim", "nano", "code", "notepad"] 
    | where { |it| (which $it | length) > 0 } 
    | first 
    | default "notepad"
)
$env.VISUAL = $env.EDITOR

$env.PAGER = "less"
$env.LESS = "-R --quit-if-one-screen --ignore-case"

# ---- Tools ------------------------------------------------------------------
$env.FZF_DEFAULT_COMMAND = 'rg --files --hidden --follow --glob "!.git"'
$env.FZF_DEFAULT_OPTS = "--height 40% --layout=reverse --border --color=bg+:#313244,bg:#1e1e2e,spinner:#f5e0dc,hl:#f38ba8 --color=fg:#cdd6f4,header:#f38ba8,info:#cba6f7,pointer:#f5e0dc --color=marker:#f5e0dc,fg+:#cdd6f4,prompt:#cba6f7,hl+:#f38ba8 --info=inline"

$env.RIPGREP_CONFIG_PATH = ($env.HOME | path join ".config" "ripgrep" "ripgreprc")

if (which delta | is-not-empty) {
    $env.GIT_PAGER = "delta"
}

# ---- Code Root --------------------------------------------------------------
# Root for all project repos and worktrees.
$env.CODE_ROOT = ($env.CODE_ROOT? | default ($env.HOME | path join "code"))

# ---- Path Setup -------------------------------------------------------------
# Standard paths to add
let extra_paths = [
    ($env.HOME | path join ".local" "bin")
    ($env.HOME | path join "bin")
    {{- if eq .chezmoi.os "darwin" }}
    "/opt/homebrew/bin"
    "/usr/local/bin"
    {{- end }}
]

# Append extra paths while keeping unique
$env.PATH = ($env.PATH | split row (char esep) | prepend $extra_paths | uniq)

# ---- Starship Prompt --------------------------------------------------------
if (which starship | is-not-empty) {
    # Generate starship init script if it doesn't exist or we want to ensure it's up to date
    let starship_cache = ($env.HOME | path join ".cache" "starship")
    if not ($starship_cache | path exists) {
        mkdir $starship_cache
    }
    let starship_init = ($starship_cache | path join "init.nu")
    starship init nu | save -f $starship_init
}

# ---- Local Exports ----------------------------------------------------------
let local_env = ($env.HOME | path join ".local_env.nu")
if ($local_env | path exists) {
    # In Nushell, we usually use 'source' or 'use' in config.nu for modularity,
    # but for env vars we can overlay or load them here if they are simple.
}
