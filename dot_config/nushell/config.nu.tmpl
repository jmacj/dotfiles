# ---- Custom Commands (Functions) --------------------------------------------

# Create directory and cd into it
def --env mkcd [path: string] {
    mkdir $path
    cd $path
}

# Go up N directories
def --env up [n: int = 1] {
    let path = (1..$n | reduce -f . {|i, acc| $acc | path join ..})
    cd $path
}

# Get weather report
def weather [location?: string] {
    curl -s $"wttr.in/($location | default '')?format=3"
}

# Copy SSH public key to clipboard
def pubkey [] {
    let key = ($env.HOME | path join ".ssh" "id_ed25519.pub")
    if ($key | path exists) {
        {{- if eq .chezmoi.os "darwin" }}
        open $key | pbcopy
        {{- else if eq .chezmoi.os "windows" }}
        open $key | clip.exe
        {{- else }}
        cat $key
        {{- end }}
        print "=> Public key copied to clipboard."
    } else {
        print "Error: Public key not found."
    }
}

# Simple backup
def backup [file: string] {
    let timestamp = (date now | format date "%Y%m%d_%H%M%S")
    cp -v $file $"($file).bak.($timestamp)"
}

# Extract common archive formats
def extract [file: string] {
    if not ($file | path exists) {
        print $"'($file)' is not a file"
        return
    }
    match ($file | str lowercase) {
        $f if ($f | str ends-with ".tar.bz2") => { tar xvjf $file }
        $f if ($f | str ends-with ".tar.gz") => { tar xvzf $file }
        $f if ($f | str ends-with ".tar.xz") => { tar xvJf $file }
        $f if ($f | str ends-with ".tar") => { tar xvf $file }
        $f if ($f | str ends-with ".bz2") => { bunzip2 $file }
        $f if ($f | str ends-with ".gz") => { gunzip $file }
        $f if ($f | str ends-with ".zip") => { unzip $file }
        $f if ($f | str ends-with ".7z") => { 7z x $file }
        $f if ($f | str ends-with ".rar") => { unrar x $file }
        $f if ($f | str ends-with ".zst") => { unzstd $file }
        _ => { print $"Unknown archive format: '($file)'" }
    }
}

# Networking
def ip [] { curl -s ifconfig.me }
def localip [] {
    {{- if eq .chezmoi.os "windows" }}
    (powershell.exe -Command "Get-NetIPAddress -AddressFamily IPv4 | Where-Object { $_.IPAddress -notlike '127.*' -and $_.IPAddress -notlike '169.254.*' } | Select-Object -First 1 -ExpandProperty IPAddress" | str trim)
    {{- else }}
    (hostname -I | split row ' ' | first)
    {{- end }}
}

# ---- Git Worktree Management ------------------------------------------------

# Add worktree
def --env wta [branch: string, base: string = "main"] {
    let root_status = (git rev-parse --show-toplevel | complete)
    if $root_status.exit_code != 0 { return }
    let root = ($root_status.stdout | str trim)
    
    let code_root = $env.CODE_ROOT
    let rel = ($root | str replace $code_root "" | str replace "^[/\\]" "")
    let wtpath = ($code_root | path join $"($rel).worktrees" $branch)
    
    mkdir ($wtpath | path dirname)
    
    if (git show-ref --verify --quiet $"refs/heads/($branch)" | complete | get exit_code) == 0 {
        git worktree add $wtpath $branch
    } else if (git ls-remote --exit-code --heads origin $branch | complete | get exit_code) == 0 {
        print $"Branch '($branch)' found on remote — fetching"
        git fetch origin $branch
        git worktree add $wtpath --track -b $branch $"origin/($branch)"
    } else {
        print $"Branch '($branch)' not found locally or remotely — creating from '($base)'"
        git worktree add -b $branch $wtpath $base
    }
    
    if (".env" | path exists) {
        cp .env ($wtpath | path join ".env")
        print "✓ .env copied"
    }
    
    cd $wtpath
    print $"✓ Worktree ready: ($wtpath)"
}

# PR into worktree
def --env cpr [pr: string, remote: string = "origin"] {
    let root_status = (git rev-parse --show-toplevel | complete)
    if $root_status.exit_code != 0 { return }
    let root = ($root_status.stdout | str trim)
    
    let branch = (gh pr view $pr --json headRefName -q .headRefName | str trim)
    if ($branch | is-empty) {
        print $"✗ PR #($pr) not found"
        return
    }
    
    let code_root = $env.CODE_ROOT
    let rel = ($root | str replace $code_root "" | str replace "^[/\\]" "")
    let wtpath = ($code_root | path join $"($rel).worktrees" $branch)
    
    mkdir ($wtpath | path dirname)
    git fetch $remote $branch
    git worktree add $wtpath $branch
    
    if (".env" | path exists) {
        cp .env ($wtpath | path join ".env")
        print "✓ .env copied"
    }
    
    cd $wtpath
    print $"✓ PR #($pr) ready: ($branch)"
}

# List worktrees
def wtls [] {
    git worktree list --porcelain 
    | lines 
    | reduce -f {wt: [], current: {}} {|line, acc| 
        if ($line | str starts-with "worktree ") {
            let path = ($line | str replace "worktree " "")
            $acc | upsert current {path: $path}
        } else if ($line | str starts-with "branch ") {
            let branch = ($line | str replace "branch " "")
            let item = ($acc.current | upsert branch $branch)
            $acc | upsert wt ($acc.wt | append $item)
        } else {
            $acc
        }
    } 
    | get wt
}

# Remove worktree
def --env wtr [branch?: string] {
    let root_status = (git worktree list --porcelain | lines | first | str replace "worktree " "" | complete)
    if $root_status.exit_code != 0 { return }
    let root = ($root_status.stdout | str trim)
    
    let code_root = $env.CODE_ROOT
    let rel = ($root | str replace $code_root "" | str replace "^[/\\]" "")
    
    var target_branch = $branch
    if ($target_branch | is-empty) {
        let options = (wtls | where path =~ $"($rel).worktrees" | get branch | str replace "refs/heads/" "")
        if ($options | is-empty) {
            print "No worktrees to remove."
            return
        }
        $target_branch = ($options | str join "\n" | fzf --prompt="Remove Worktree > " --height=~40% --layout=reverse --border | str trim)
    }
    
    if ($target_branch | is-empty) { return }
    
    let wtpath = ($code_root | path join $"($rel).worktrees" $target_branch)
    
    if ($env.PWD | str starts-with $wtpath) {
        cd $root
    }
    
    git worktree remove $wtpath --force
    git branch -d $target_branch | complete
    git worktree prune
    print $"✓ Removed and pruned: ($target_branch)"
}

# Jump to worktree
def --env cdwt [] {
    let wt = (wtls | get path | str join "\n" | fzf --prompt="Jump to Worktree > " --height=~40% --layout=reverse --border | str trim)
    if ($wt | is-not-empty) {
        cd $wt
    }
}

# Done with worktree
def --env wtdone [] {
    let root_status = (git worktree list --porcelain | lines | first | str replace "worktree " "" | complete)
    if $root_status.exit_code != 0 { return }
    let root = ($root_status.stdout | str trim)
    
    let branch = (git rev-parse --abbrev-ref HEAD | str trim)
    if ($branch == "main" or $branch == "master") {
        print "✗ You're on main/master — run this from inside a feature worktree"
        return
    }
    
    let code_root = $env.CODE_ROOT
    let rel = ($root | str replace $code_root "" | str replace "^[/\\]" "")
    let wtpath = ($code_root | path join $"($rel).worktrees" $branch)
    
    cd $root
    git worktree remove $wtpath --force
    git branch -d $branch | complete
    git worktree prune
    print $"✓ Done with '($branch)', back at ($rel) root"
}

