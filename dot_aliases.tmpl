# shellcheck shell=bash
# =============================================================================
# ~/.aliases  —  shared aliases, sourced by .bashrc and .zshrc
# OS-conditional blocks use chezmoi's Go template syntax (processed at apply).
# =============================================================================

# ---- Navigation -------------------------------------------------------------
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias ~='cd ~'

# ---- List files -------------------------------------------------------------
# Use eza if available, fall back to ls
if command -v eza &>/dev/null; then
  alias ls='eza --group-directories-first'
  alias ll='eza -lhF --group-directories-first --git -u --header'
  alias la='eza -lhAF --group-directories-first --git -u --header'
  alias tree='eza --tree'
else
  {{- if eq .chezmoi.os "darwin" }}
  alias ls='ls -G'
  alias ll='ls -lhFG'
  alias la='ls -lhAFG'
  {{- else if eq .chezmoi.os "windows" }}
  alias ls='ls --color=auto'
  alias ll='ls -lhF --color=auto'
  alias la='ls -lhAF --color=auto'
  {{- else }}
  alias ls='ls --color=auto'
  alias ll='ls -lhF --color=auto'
  alias la='ls -lhAF --color=auto'
  {{- end }}
fi

# ---- Git shortcuts ----------------------------------------------------------
alias gs='git status'
alias ga='git add'
alias gc='git commit'
alias gcm='git commit -m'
alias gca='git commit --amend'
alias gco='git checkout'
alias gcb='git checkout -b'
alias gp='git push'
alias gm='git merge'
alias gmnf='git merge --no-ff'
alias gpl='git pull'
alias gf='git fetch'
alias gl='git log --graph --pretty=format:"%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset" --abbrev-commit'
alias gd='git diff'
alias gds='git diff --staged'
alias gst='git stash'
alias gstp='git stash pop'
alias gbr='git branch'
alias gundo='git reset --soft HEAD~1'

# ---- Sudo (allow alias expansion) -------------------------------------------
alias sudo='sudo '

# ---- Utilities --------------------------------------------------------------
alias grep='grep --color=auto'
alias mkdir='mkdir -pv'
alias df='df -h'
alias du='du -h'
{{- if eq .chezmoi.os "linux" }}
alias free='free -h'
{{- else if eq .chezmoi.os "darwin" }}
alias free='top -l 1 -s 0 | grep PhysMem'
{{- else if eq .chezmoi.os "windows" }}
alias free='powershell.exe -Command "Get-CimInstance Win32_OperatingSystem | Select-Object @{n=\"Total(MB)\";e={[math]::Round(\$_.TotalVisibleMemorySize/1024)}}, @{n=\"Free(MB)\";e={[math]::Round(\$_.FreePhysicalMemory/1024)}} | Format-Table -AutoSize"'
{{- end }}

# ---- Networking -------------------------------------------------------------
alias ip='curl -s ifconfig.me'
{{- if eq .chezmoi.os "linux" }}
alias localip='hostname -I | awk "{print \$1}"'
{{- else if eq .chezmoi.os "darwin" }}
alias localip='ipconfig getifaddr en0'
{{- else if eq .chezmoi.os "windows" }}
alias localip='powershell.exe -Command "Get-NetIPAddress -AddressFamily IPv4 | Where-Object { \$_.IPAddress -notlike \"127.*\" -and \$_.IPAddress -notlike \"169.254.*\" } | Select-Object -First 1 -ExpandProperty IPAddress"'
{{- end }}
alias ports='netstat -tulanp 2>/dev/null || netstat -an'

# Copy SSH public key to clipboard
{{- if eq .chezmoi.os "darwin" }}
alias pubkey='[ -f ~/.ssh/id_ed25519.pub ] && pbcopy < ~/.ssh/id_ed25519.pub && echo "=> Public key copied to clipboard." || echo "Error: Public key not found."'
{{- else if eq .chezmoi.os "windows" }}
alias pubkey='[ -f ~/.ssh/id_ed25519.pub ] && clip.exe < ~/.ssh/id_ed25519.pub && echo "=> Public key copied to clipboard." || echo "Error: Public key not found."'
{{- else }}
alias pubkey='[ -f ~/.ssh/id_ed25519.pub ] && (command -v xclip >/dev/null && xclip -sel clip < ~/.ssh/id_ed25519.pub || command -v xsel >/dev/null && xsel --clipboard --input < ~/.ssh/id_ed25519.pub || cat ~/.ssh/id_ed25519.pub) && echo "=> Public key copied to clipboard (or printed above)."'
{{- end }}

# ---- System -----------------------------------------------------------------
# ---- Dev & Utilities --------------------------------------------------------
alias serve='python3 -m http.server 8000'
alias path='echo $PATH | tr ":" "\n"'

# ---- npm --------------------------------------------------------------------
alias ni='npm install'
alias nci='npm ci'
alias nad='npm install -D'
alias nu='npm update'
alias nun='npm uninstall'
alias nx='npx'
alias nr='npm run'
alias ns='npm start'
alias nt='npm test'
alias nd='npm run dev'
alias npmls='npm list --depth=0'
alias npmg='npm list -g --depth=0'

# ---- pnpm -------------------------------------------------------------------
alias pi='pnpm install'
alias pci='pnpm install --frozen-lockfile'
alias pa='pnpm add'
alias pad='pnpm add -D'
alias pu='pnpm update'
alias pun='pnpm uninstall'
alias px='pnpm dlx'
alias pr='pnpm run'
alias ps='pnpm start'
alias pt='pnpm test'
alias pd='pnpm dev'

# ---- Open (cross-platform) --------------------------------------------------
{{- if eq .chezmoi.os "darwin" }}
alias open='open'
{{- else if eq .chezmoi.os "linux" }}
alias open='xdg-open'
{{- end }}

# ---- Local aliases (not committed) ------------------------------------------
# shellcheck source=/dev/null
[ -f "$HOME/.local_aliases" ] && source "$HOME/.local_aliases"
