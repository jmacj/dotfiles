# =============================================================================
# Microsoft.PowerShell_profile.ps1  —  PowerShell profile (Windows)
# Applies to: PowerShell 7+ (pwsh), also compatible with Windows PowerShell 5.1
# =============================================================================

# ---- Starship prompt --------------------------------------------------------
if (Get-Command starship -ErrorAction SilentlyContinue) {
    $ENV:STARSHIP_SHELL = "powershell"
    $ENV:STARSHIP_SESSION_KEY = [System.Guid]::NewGuid().ToString()
    Invoke-Expression (&starship init powershell)
}

# ---- fzf key bindings -------------------------------------------------------
$fzfProfile = "$HOME\.config\fzf\fzf.ps1"
if (Test-Path $fzfProfile) { . $fzfProfile }

# ---- PSReadLine (Modern shell experience) -----------------------------------
if (Get-Module -ListAvailable PSReadLine) {
    Set-PSReadLineOption -EditMode Emacs
    Set-PSReadLineOption -BellStyle None
    # Modern PSReadLine features (Available in v2.1.0+)
    $psrlVersion = (Get-Module -ListAvailable PSReadLine | Sort-Object Version -Descending)[0].Version
    if ($psrlVersion -ge [version]"2.1.0") {
        Set-PSReadLineOption -PredictionSource History
        Set-PSReadLineOption -PredictionViewStyle ListView
    }
    # Key bindings for history search
    Set-PSReadLineKeyHandler -Key UpArrow -Function HistorySearchBackward
    Set-PSReadLineKeyHandler -Key DownArrow -Function HistorySearchForward
}

# ---- Aliases ----------------------------------------------------------------
Set-Alias which Get-Command
Set-Alias touch New-Item
Set-Alias grep  Select-String

# Remove built-in aliases that conflict with custom functions (Git shortcuts, ls, etc.)
$conflictingAliases = @('gc', 'gs', 'gp', 'gl', 'gd', 'sc', 'gcb', 'ls')
foreach ($a in $conflictingAliases) {
    if (Test-Path "Alias:\$a") { Remove-Item "Alias:\$a" -Force -ErrorAction SilentlyContinue }
}

# Navigation
function ..   { Set-Location .. }
function ...  { Set-Location ..\.. }
function .... { Set-Location ..\..\.. }
function ~    { Set-Location $HOME }

# File listing (eza/ls)
if (Get-Command eza -ErrorAction SilentlyContinue) {
    function ls { eza --group-directories-first @args }
    function ll { eza -lhF --group-directories-first --git -u --header @args }
    function la { eza -lhAF --group-directories-first --git -u --header @args }
    function tree { eza --tree @args }
} else {
    # Fallback to native Get-ChildItem if eza is missing
    function ll { Get-ChildItem -Force $args }
    function la { Get-ChildItem -Force $args }
}

# Git aliases (only for common commands not in .gitconfig or where built-in overlap exists)
function gs  { git status $args }
function ga  { git add $args }
function gc  { git commit $args }
function gcm { git commit -m "$args" }
function gca { git commit --amend $args }
function gco { git checkout $args }
function gcb { git checkout -b $args }
function gm  { git merge $args }
function gmnf { git merge --no-ff $args }
function gp  { git push $args }
function gpl { git pull $args }
function gf  { git fetch $args }
function gl  { git log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit $args }
function gd  { git diff $args }
function gds { git diff --staged $args }
function gst { git stash $args }
function gstp { git stash pop $args }
function gbr { git branch $args }
function gundo { git reset --soft HEAD~1 }

# ---- Utilities --------------------------------------------------------------
function mkcd {
    param([string]$Path)
    New-Item -ItemType Directory -Force -Path $Path | Out-Null
    Set-Location $Path
}

function reload { & $PROFILE }

# ---- npm --------------------------------------------------------------------
function ni  { npm install $args }
function nci { npm ci $args }
function nad { npm install -D $args }
function nu  { npm update $args }
function nun { npm uninstall $args }
function nx  { npx $args }
function nr  { npm run $args }
function ns  { npm start $args }
function nt  { npm test $args }
function nd  { npm run dev $args }

function pubkey {
    $keyPath = "$HOME\.ssh\id_ed25519.pub"
    if (Test-Path $keyPath) {
        Get-Content $keyPath | Set-Clipboard
        Write-Host "Public key copied to clipboard."
    } else {
        Write-Warning "No SSH public key found at $keyPath"
    }
}

function weather {
    param([string]$Location = "")
    curl -s "wttr.in/$($Location)?format=3"
}

function ip { curl -s ifconfig.me }
function localip { (Get-NetIPAddress -AddressFamily IPv4 | Where-Object { $_.InterfaceAlias -notlike "*Loopback*" }).IPAddress | Select-Object -First 1 }
function ports { Get-NetTCPConnection -State Listen | Select-Object LocalAddress, LocalPort, State | Sort-Object LocalPort }

function path { $ENV:PATH -split ";" }

function port {
    param([int]$PortNumber)
    $process = Get-NetTCPConnection -LocalPort $PortNumber -ErrorAction SilentlyContinue
    if ($process) {
        Stop-Process -Id $process.OwningProcess -Force
        Write-Host "Killed process on port $PortNumber"
    } else {
        Write-Warning "No process found on port $PortNumber"
    }
}

# ---- Dev & Open -------------------------------------------------------------
function serve { python -m http.server 8000 }
function npmls { npm list --depth=0 }
function npmg { npm list -g --depth=0 }

# ---- pnpm -------------------------------------------------------------------
function pi  { pnpm install $args }
function pci { pnpm install --frozen-lockfile $args }
function pa  { pnpm add $args }
function pad { pnpm add -D $args }
function pu  { pnpm update $args }
function pun { pnpm uninstall $args }
function px  { pnpm dlx $args }
function pr  { pnpm run $args }
function ps  { pnpm start $args }
function pt  { pnpm test $args }
function pd  { pnpm dev $args }

function open  { Start-Process $args }

# ---- Environment ------------------------------------------------------------
# Resilient EDITOR selection
$potentialEditors = @("vim", "nvim", "nano", "code", "notepad")
$ENV:EDITOR = ($potentialEditors | Where-Object { Get-Command $_ -ErrorAction SilentlyContinue } | Select-Object -First 1)
if (-not $ENV:EDITOR) { $ENV:EDITOR = "notepad" }
$ENV:VISUAL = $ENV:EDITOR

$ENV:FZF_DEFAULT_COMMAND = 'rg --files --hidden --follow --glob "!.git"'
$ENV:FZF_DEFAULT_OPTS = '--height 40% --layout=reverse --border'
$ENV:RIPGREP_CONFIG_PATH = "$HOME\.config\ripgrep\ripgreprc"
if (Get-Command delta -ErrorAction SilentlyContinue) { $ENV:GIT_PAGER = "delta" }

# ---- Local overrides (not committed) ----------------------------------------
$localProfile = "$HOME\.local_profile.ps1"
if (Test-Path $localProfile) { . $localProfile }
