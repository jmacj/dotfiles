# ---- Environment ------------------------------------------------------------
# Resilient EDITOR selection
$potentialEditors = @("vim", "nvim", "nano", "code", "notepad")
$ENV:EDITOR = ($potentialEditors | Where-Object { Get-Command $_ -ErrorAction SilentlyContinue } | Select-Object -First 1)
if (-not $ENV:EDITOR) { $ENV:EDITOR = "notepad" }
$ENV:VISUAL = $ENV:EDITOR

$ENV:FZF_DEFAULT_COMMAND = 'rg --files --hidden --follow --glob "!.git"'
$ENV:FZF_DEFAULT_OPTS = '--height 40% --layout=reverse --border'
$ENV:RIPGREP_CONFIG_PATH = "$HOME\.config\ripgrep\ripgreprc"
if (Get-Command delta -ErrorAction SilentlyContinue) { $ENV:GIT_PAGER = "delta" }

# ---- Local overrides (not committed) ----------------------------------------
$localProfile = "$HOME\.local_profile.ps1"
if (Test-Path $localProfile) { . $localProfile }
